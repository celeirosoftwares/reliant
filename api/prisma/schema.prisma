// Prisma Schema — Reliant MVP
// postgresql + JSONB for schemas and outputs

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DATABASE_URL")
}

model Project {
  id         String   @id @default(cuid())
  name       String
  apiKey     String   @unique @map("api_key")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  schemas    Schema[]
  executions Execution[]

  @@map("projects")
}

model Schema {
  id               String   @id @default(cuid())
  projectId        String   @map("project_id")
  name             String
  slug             String
  version          Int      @default(1)
  description      String?
  definition       Json
  safeFallback     Json?    @map("safe_fallback")
  systemPrompt     String?  @map("system_prompt")
  fallbackProviders Json?   @map("fallback_providers")
  isActive         Boolean  @default(true) @map("is_active")
  createdAt        DateTime @default(now()) @map("created_at")

  project    Project     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  executions Execution[]

  @@unique([projectId, slug, version])
  @@index([projectId, slug])
  @@map("schemas")
}

model Execution {
  id               String   @id @default(cuid())
  projectId        String   @map("project_id")
  schemaId         String?  @map("schema_id")
  schemaVersion    Int?     @map("schema_version")
  provider         String
  model            String
  status           String
  attempts         Int      @default(1)
  latencyMs        Int      @map("latency_ms")
  tokensUsed       Int?     @map("tokens_used")
  inputPrompt      String   @map("input_prompt")
  output           Json?
  validationErrors Json?    @map("validation_errors")
  errorMessage     String?  @map("error_message")
  retryLog         Json?    @map("retry_log")
  createdAt        DateTime @default(now()) @map("created_at")

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  schema  Schema? @relation(fields: [schemaId], references: [id], onDelete: SetNull)

  @@index([projectId, createdAt])
  @@index([projectId, status])
  @@index([schemaId])
  @@map("executions")
}
