# Reliant API — Environment Variables
# Copy to .env and fill in your values

DATABASE_URL="postgresql://user:password@localhost:5432/reliant?schema=public"

# LLM Provider Keys (at least one required)
OPENAI_API_KEY="sk-..."
ANTHROPIC_API_KEY="sk-ant-..."
GOOGLE_AI_API_KEY="..."

# Server
PORT=3100
HOST=0.0.0.0
NODE_ENV=development

# Rate Limiting
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW_MS=60000
